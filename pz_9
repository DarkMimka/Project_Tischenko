#Даны имена девочек.
#Определить, какие из этих имен встречаются в группах на всех вторых курсах, какие есть только в некоторых группах и кие не встречаются ни в одной из групп.

group_1 = {'Анна', 'Мария', 'Екатерина', 'Ольга', 'Светлана'}
group_2 = {'Мария', 'Екатерина', 'Дарья', 'Анна'}
group_3 = {'Анна', 'Ольга', 'Татьяна', 'Екатерина'}

print('Имена, которые есть во ВСЕХ группах:', group_1 & group_2 & group_3)
print('Полный набор имён (есть хотя бы в одной группе):', group_1 | group_2 | group_3)

all_names = {'Анна', 'Мария', 'Екатерина', 'Ольга', 'Светлана', 'Дарья', 'Татьяна', 'Виктория', 'Александра'}
not_in_groups = all_names - (group_1 | group_2 | group_3)
print('Имена, которых нет ни в одной группе:', not_in_groups)

name = 'Мария'
if name in group_1 or name in group_2 or name in group_3:
    print(f'Имя "{name}" есть хотя бы в одной группе')
else:
    print(f'Имени "{name}" нет ни в одной группе')
