#На трех участках выращиваются следующие сельскохозяйственные культуры:
#Картофель, лук, морковь, горох, капуста, редис.
#Определить, какие из этих культур имеются на каждом участке, имеются хотя бы на одном из участков и не имеются ни на одном участке.

kuturi=["картофель", "редис", "лук", "морковь", "капуста", "горох"]

uch1={"картофель", "редис", "горох"}
uch2={"морковь", "картофель"}
uch3={"картофель", "лук", "редис", "горох", "морковь"}

print("На всех трех участках есть:", uch1&uch2&uch3)

for x in kulturi
  if x not in uch1|uch2|uch3:
      print("Ни на одном участке нету", x)
